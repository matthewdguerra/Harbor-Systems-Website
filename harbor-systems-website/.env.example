# Anthropic API key — required for the live AI chatbot
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the Claude model (defaults to claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: your production URL for Open Graph metadata
NEXT_PUBLIC_SITE_URL=https://harborsystems.ai
